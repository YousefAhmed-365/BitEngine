EBNF SPEC
⚙️ CORE STRUCTURE
Program        = { Statement } ;

Statement      = Config
               | VariableDecl
               | EntityBlock
               | SceneBlock
               | ";"
               ;
⚙️ CONFIG
Config         = "config" "{" { ConfigEntry } "}" ";" ;

ConfigEntry    = Identifier "=" Expression ";" ;
🧠 VARIABLES
VariableDecl   = "var" Identifier "=" Expression ";" ;
Assignment     = Identifier "=" Expression ";" ;
🧩 ENTITIES + SPRITES
EntityBlock    = "entities" "{" { Entity } "}" ";" ;

Entity         = Identifier "{" { EntityProperty } "}" ";" ;

EntityProperty = "name" "=" String ";"
               | "type" "=" Identifier ";"
               | "default_pos" "=" Position ";"
               | SpriteBlock
               ;

SpriteBlock    = "sprite" Identifier "{" { SpriteProperty } "}" ";" ;

SpriteProperty = "path" "=" String ";"
               | "frames" "=" Number ";"
               | "speed" "=" Number ";"
               | "scale" "=" Number ";"
               ;
🎬 SCENES
SceneBlock     = "scene" Identifier "{" { SceneStatement } "}" ";" ;
🎭 SCENE STATEMENTS
SceneStatement = Dialogue
               | ChoiceBlock
               | Assignment
               | IfStatement
               | JumpStatement
               | ExpressionStatement
               ;
💬 DIALOGUE
Dialogue       = Identifier ModifierBlock ":" String ";" ;

ModifierBlock  = "[" { Modifier } "]" ;

Modifier       = Identifier "=" Expression ;
🎮 CHOICES
ChoiceBlock    = "choice" "{" { ChoiceOption } "}" ";" ;

ChoiceOption   = String "->" Identifier [ "if" Expression ] ";" ;
🔁 CONTROL FLOW
JumpStatement  = "jump" Identifier ";" ;

IfStatement    = "if" "(" Expression ")" "{" { SceneStatement } "}" ";" ;
🧮 EXPRESSIONS (CORE OF THE LANGUAGE)

This is the most important part.

EXPRESSION RULES
Expression     = LogicalExpr ;

LogicalExpr    = ComparisonExpr { ("and" | "or") ComparisonExpr } ;

ComparisonExpr = AddExpr [ CompareOp AddExpr ] ;

AddExpr        = MulExpr { ("+" | "-") MulExpr } ;

MulExpr        = UnaryExpr { ("*" | "/") UnaryExpr } ;

UnaryExpr      = [ "-" | "!" ] Primary ;

Primary        = Number
               | String
               | Identifier
               | Boolean
               | "(" Expression ")"
               ;
COMPARISON OPERATORS
CompareOp      = "==" | "!=" | "<" | ">" | "<=" | ">=" ;
🧱 LITERALS
Number         = Digit { Digit } [ "." Digit { Digit } ] ;
String         = "\"" { AnyChar } "\"" ;
Boolean        = "true" | "false" ;
Identifier     = Letter { Letter | Digit | "_" } ;
Position       = "left" | "right" | "center" | Number ;
🧠 INLINE SCENE EXPRESSIONS
ExpressionStatement = Assignment | FunctionCall ;

FunctionCall        = Identifier "(" [ ArgumentList ] ")" ";" ;

ArgumentList        = Expression { "," Expression } ;